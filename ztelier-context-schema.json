{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ztelier.local/schemas/ztelier-context/1.1.0",
  "title": "Ztelier Context",
  "description": "Ztelier スイート全ツールが共有する単一セッションの評価コンテキスト。Amplify / MAAZ / Showtoku / Forg / Endeavor の結果を統一スキーマで保持する。Forg は実装 v4.1.0+ の変数定義・計算式を正統化（v1.1.0）。",
  "type": "object",
  "required": ["meta", "customer"],
  "additionalProperties": false,
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "customer": { "$ref": "#/$defs/customer" },
    "amplify": { "$ref": "#/$defs/amplify" },
    "maaz": { "$ref": "#/$defs/maaz" },
    "showtoku": { "$ref": "#/$defs/showtoku" },
    "forg": { "$ref": "#/$defs/forg" },
    "endeavor": { "$ref": "#/$defs/endeavor" }
  },

  "$defs": {
    "meta": {
      "type": "object",
      "description": "スキーマ・セッションのメタ情報。3層バージョニング（schema_version / ztelier_version / 各ツールversion）を担保。",
      "required": ["schema_version", "ztelier_version", "session_id", "created_at"],
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "type": "string",
          "description": "このスキーマ定義のバージョン（SemVer）。",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "const": "1.1.0"
        },
        "ztelier_version": {
          "type": "string",
          "description": "Ztelier プロジェクト全体のバージョン（SemVer）。",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "session_id": {
          "type": "string",
          "description": "セッション識別子。推奨フォーマット: aw-YYYYMMDD-<customer-slug>",
          "minLength": 1,
          "maxLength": 128,
          "examples": ["aw-20260417-company-a"]
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "初期作成日時（ISO 8601、JST推奨）"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "最終更新日時"
        },
        "created_by": {
          "type": ["string", "null"],
          "description": "作成者識別子（SE名等）",
          "maxLength": 128
        }
      }
    },

    "customer": {
      "type": "object",
      "description": "顧客情報。全ツール共通参照。ShowtokuのICP判定、Endeavorの被害額算出にも使用。",
      "required": ["company_name"],
      "additionalProperties": false,
      "properties": {
        "company_name": {
          "type": "string",
          "description": "顧客企業名（日本語表記可）",
          "minLength": 1,
          "maxLength": 256
        },
        "industry": {
          "type": ["string", "null"],
          "description": "業種コード（英小文字アンダースコア）",
          "enum": [
            "manufacturing",
            "financial_services",
            "retail",
            "healthcare",
            "pharma",
            "energy_utilities",
            "telecom",
            "government",
            "education",
            "media",
            "logistics",
            "construction",
            "professional_services",
            "technology",
            "other",
            null
          ]
        },
        "industry_label": {
          "type": ["string", "null"],
          "description": "業種表示名（日本語）",
          "examples": ["製造業", "金融サービス", "小売"]
        },
        "employee_count_range": {
          "type": ["string", "null"],
          "description": "従業員数レンジ",
          "enum": [
            "under_100",
            "100-500",
            "500-1000",
            "1000-5000",
            "5000-10000",
            "10000-50000",
            "over_50000",
            null
          ]
        },
        "annual_revenue_range": {
          "type": ["string", "null"],
          "description": "年間売上レンジ（JPY）。Endeavor 被害額試算のベース。",
          "enum": [
            "under_1B_JPY",
            "1B-10B_JPY",
            "10B-100B_JPY",
            "100B-500B_JPY",
            "500B-1T_JPY",
            "over_1T_JPY",
            null
          ]
        },
        "headquarters_location": {
          "type": ["string", "null"],
          "description": "本社所在国コード（ISO 3166-1 alpha-2）",
          "pattern": "^[A-Z]{2}$"
        },
        "current_zscaler_status": {
          "type": ["string", "null"],
          "description": "現在のZscaler利用状況",
          "enum": ["prospect", "poc", "existing_customer", "churned", "unknown", null]
        },
        "aw_context": {
          "type": ["object", "null"],
          "description": "Architecture Workshop 実施時のコンテキスト",
          "additionalProperties": false,
          "properties": {
            "aw_type": {
              "type": "string",
              "enum": ["full", "mini", "deep_dive", "follow_up", "internal"]
            },
            "duration_minutes": {
              "type": "integer",
              "minimum": 0,
              "maximum": 480
            },
            "attendees_roles": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "CEO", "CFO", "CIO", "CISO", "CTO", "COO",
                  "IT_director", "security_director",
                  "IT_manager", "security_manager",
                  "architect", "engineer",
                  "business_unit_head",
                  "procurement",
                  "other"
                ]
              },
              "uniqueItems": true
            },
            "partner_involved": {
              "type": ["string", "null"],
              "description": "パートナー名（間接販売モデル）"
            }
          }
        }
      }
    },

    "amplify": {
      "type": "object",
      "description": "Amplify 結果：顧客の課題選択からZscalerソリューションとZTMM 5ピラーへのマッピング",
      "required": ["completed"],
      "additionalProperties": false,
      "properties": {
        "completed": { "type": "boolean" },
        "version": { "type": ["string", "null"], "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "selected_use_cases": {
          "type": "array",
          "description": "顧客が選択したユースケース",
          "items": {
            "type": "object",
            "required": ["use_case_id"],
            "additionalProperties": false,
            "properties": {
              "use_case_id": { "type": "string" },
              "use_case_label_ja": { "type": ["string", "null"] },
              "priority": { "type": ["string", "null"], "enum": ["high", "medium", "low", null] }
            }
          }
        },
        "ztmm_pillar_mapping": {
          "type": ["object", "null"],
          "description": "選択ユースケース→ZTMM 5ピラーマッピング（0-1スコア）",
          "additionalProperties": false,
          "properties": {
            "identity":     { "type": "number", "minimum": 0, "maximum": 1 },
            "devices":      { "type": "number", "minimum": 0, "maximum": 1 },
            "networks":     { "type": "number", "minimum": 0, "maximum": 1 },
            "applications": { "type": "number", "minimum": 0, "maximum": 1 },
            "data":         { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "recommended_zscaler_products": {
          "type": "array",
          "description": "推奨Zscaler製品コード",
          "items": {
            "type": "string",
            "enum": [
              "ZIA", "ZPA", "ZDX",
              "ZT_Browser", "ZT_SASE",
              "ZRA",
              "Posture_Control",
              "Data_Protection",
              "AI_Security",
              "Risk360",
              "Z_Flex",
              "other"
            ]
          },
          "uniqueItems": true
        },
        "executive_summary_1line": {
          "type": ["string", "null"],
          "description": "経営層向け1行サマリ（日本語、60字以内推奨）",
          "maxLength": 200
        }
      }
    },

    "maaz": {
      "type": "object",
      "description": "MAAZ 結果：MITRE ATT&CK + ATLASのテクニックレベルでZT実装評価、CISA ZTMM 5ピラー成熟度統合",
      "required": ["completed"],
      "additionalProperties": false,
      "properties": {
        "completed": { "type": "boolean" },
        "version": { "type": ["string", "null"], "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "ztmm_maturity": {
          "type": ["object", "null"],
          "description": "CISA ZTMM 5ピラー成熟度（+ Cross-Cutting Governance）。Endeavor左レーダー6軸の元データ。",
          "additionalProperties": false,
          "required": ["identity", "devices", "networks", "applications", "data", "cross_cutting_governance"],
          "properties": {
            "identity":                 { "$ref": "#/$defs/ztmm_pillar_score" },
            "devices":                  { "$ref": "#/$defs/ztmm_pillar_score" },
            "networks":                 { "$ref": "#/$defs/ztmm_pillar_score" },
            "applications":             { "$ref": "#/$defs/ztmm_pillar_score" },
            "data":                     { "$ref": "#/$defs/ztmm_pillar_score" },
            "cross_cutting_governance": { "$ref": "#/$defs/ztmm_pillar_score" }
          }
        },
        "overall_level": {
          "type": ["string", "null"],
          "description": "総合成熟度レベル",
          "enum": ["Traditional", "Initial", "Advanced", "Optimal", null]
        },
        "attack_technique_coverage": {
          "type": ["object", "null"],
          "description": "MITRE ATT&CK テクニックカバレッジ",
          "additionalProperties": false,
          "properties": {
            "total_techniques_evaluated": { "type": "integer", "minimum": 0 },
            "covered_count": { "type": "integer", "minimum": 0 },
            "coverage_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "covered_technique_ids": {
              "type": "array",
              "items": { "type": "string", "pattern": "^T\\d{4}(\\.\\d{3})?$" },
              "uniqueItems": true
            }
          }
        },
        "atlas_technique_coverage": {
          "type": ["object", "null"],
          "description": "MITRE ATLAS（AI Security）テクニックカバレッジ",
          "additionalProperties": false,
          "properties": {
            "total_techniques_evaluated": { "type": "integer", "minimum": 0 },
            "covered_count": { "type": "integer", "minimum": 0 },
            "coverage_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "covered_technique_ids": {
              "type": "array",
              "items": { "type": "string", "pattern": "^AML\\.T\\d{4}(\\.\\d{3})?$" },
              "uniqueItems": true
            }
          }
        },
        "priority_gaps": {
          "type": "array",
          "description": "優先対処ギャップ（スコア低＋攻撃可能性高）",
          "items": {
            "type": "object",
            "required": ["pillar", "severity"],
            "additionalProperties": false,
            "properties": {
              "pillar": {
                "type": "string",
                "enum": ["identity", "devices", "networks", "applications", "data", "cross_cutting_governance"]
              },
              "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
              "description_ja": { "type": ["string", "null"] },
              "related_techniques": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              }
            }
          }
        }
      }
    },

    "showtoku": {
      "type": "object",
      "description": "Showtoku 結果：NIST CSF 2.0 + AI RMF 1.0/GenAI Profileのギャップ分析（憲法層評価）",
      "required": ["completed"],
      "additionalProperties": false,
      "properties": {
        "completed": { "type": "boolean" },
        "version": { "type": ["string", "null"], "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "csf_maturity": {
          "type": ["object", "null"],
          "description": "NIST CSF 2.0 6機能の成熟度。Endeavor右レーダー6軸の元データ。",
          "additionalProperties": false,
          "required": ["govern", "identify", "protect", "detect", "respond", "recover"],
          "properties": {
            "govern":   { "$ref": "#/$defs/csf_function_score" },
            "identify": { "$ref": "#/$defs/csf_function_score" },
            "protect":  { "$ref": "#/$defs/csf_function_score" },
            "detect":   { "$ref": "#/$defs/csf_function_score" },
            "respond":  { "$ref": "#/$defs/csf_function_score" },
            "recover":  { "$ref": "#/$defs/csf_function_score" }
          }
        },
        "ai_rmf_maturity": {
          "type": ["object", "null"],
          "description": "NIST AI RMF 1.0 / GenAI Profile 成熟度",
          "additionalProperties": false,
          "properties": {
            "govern":  { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "map":     { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "measure": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "manage":  { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
          }
        },
        "priority_subcategories": {
          "type": "array",
          "description": "優先対処CSFサブカテゴリ（106件中）",
          "items": {
            "type": "object",
            "required": ["subcategory_id"],
            "additionalProperties": false,
            "properties": {
              "subcategory_id": {
                "type": "string",
                "description": "CSF 2.0 サブカテゴリID（例: GV.OC-01, ID.AM-01）",
                "pattern": "^(GV|ID|PR|DE|RS|RC)\\.[A-Z]{2}-\\d{2}$"
              },
              "current_tier": { "type": ["integer", "null"], "minimum": 1, "maximum": 4 },
              "target_tier":  { "type": ["integer", "null"], "minimum": 1, "maximum": 4 },
              "note_ja": { "type": ["string", "null"] }
            }
          }
        }
      }
    },

    "forg": {
      "type": "object",
      "description": "Forg 結果：組織摩擦診断（物理学的アナロジー forg = (S × L) / (C × LP)）。実装 v4.1.0+ 準拠。",
      "required": ["completed"],
      "additionalProperties": false,
      "properties": {
        "completed": { "type": "boolean" },
        "version": { "type": ["string", "null"], "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "variables": {
          "type": ["object", "null"],
          "description": "Forg 4変数。各変数は設問群（S×5, L×5, C×4, LP×5）の平均値で、1-5スケール（1=最良, 5=最悪）。S/L は分子（摩擦）、C/LP は分母（推進力）。",
          "additionalProperties": false,
          "required": ["S", "L", "C", "LP"],
          "properties": {
            "S":  { "type": "number", "minimum": 0, "maximum": 5, "description": "Structure / Silo：縦割り組織の壁（分子=摩擦）。高いほど壁が厚い。" },
            "L":  { "type": "number", "minimum": 0, "maximum": 5, "description": "Legacy：技術的負債・資産（分子=摩擦）。高いほど負債が深い。" },
            "C":  { "type": "number", "minimum": 0, "maximum": 5, "description": "Crisis / Cost：金銭的危機感（分母=推進力）。高いほど変革の原動力が強い。" },
            "LP": { "type": "number", "minimum": 0, "maximum": 5, "description": "Leadership：変革断行への意志（分母=推進力）。高いほど推進力が強い。Primed (lp_adj) を格納。" }
          }
        },
        "variables_raw": {
          "type": ["object", "null"],
          "description": "矛盾検出によるLP補正前の生値。lp_raw のみ保持。",
          "additionalProperties": false,
          "properties": {
            "lp_raw": { "type": ["number", "null"], "minimum": 0, "maximum": 5, "description": "Leadership生値（矛盾検出で0.85x/0.9x減衰される前の値）" }
          }
        },
        "budget_ratio": {
          "type": ["object", "null"],
          "description": "IT予算/売上高の比率計算（C3 の自動算出入力）。実装 v4.1.0+ の budgetRatio / budgetScore を保持。",
          "additionalProperties": false,
          "properties": {
            "it_budget_jpy": { "type": ["number", "null"], "minimum": 0, "description": "年間IT予算（円）" },
            "annual_revenue_jpy": { "type": ["number", "null"], "minimum": 0, "description": "年間売上（円）" },
            "ratio_percent": { "type": ["number", "null"], "minimum": 0, "description": "(it_budget / revenue) × 100。日本中央値3.2%・グローバル5.5%・US 8.2%" },
            "score": { "type": ["integer", "null"], "minimum": 0, "maximum": 5, "description": "budgetRatio から 1-5 スコア変換（C 計算の一要素）" }
          }
        },
        "F_value": {
          "type": ["number", "null"],
          "description": "組織摩擦係数 forg = (S × L) / (C × LP)。0に近いほど低摩擦（加速帯）。C × LP = 0 の場合は 99 を返す（分母ゼロ例外）。UI上は 10.0+ で打ち切り表示。",
          "minimum": 0
        },
        "F_status": {
          "type": ["string", "null"],
          "description": "F値の定性判定。実装 v4.1.0 の forgStatus 準拠。",
          "enum": ["変革の加速帯", "変革の停滞帯", "変革の膠着帯", "入力待ち...", null]
        },
        "industry_average_F": {
          "type": ["number", "null"],
          "description": "該当業界の平均F値（250社AW実績ベース、業界別テーブルから参照）",
          "minimum": 0
        },
        "deviation_from_average": {
          "type": ["number", "null"],
          "description": "業界平均からの偏差（F_value - industry_average_F）。正=平均より悪い、負=平均より良い。"
        },
        "archetype": {
          "type": ["object", "null"],
          "description": "C × LP の4象限アーキタイプ診断（実装 v4.1.0+ 準拠）",
          "additionalProperties": false,
          "required": ["cell_id"],
          "properties": {
            "cell_id": {
              "type": "string",
              "description": "4象限セル識別子。tr=topright, tl=topleft, br=bottomright, bl=bottomleft",
              "enum": ["tr", "tl", "br", "bl"]
            },
            "name_ja": {
              "type": "string",
              "description": "アーキタイプ名",
              "examples": ["変革の臨界点（Zenith型）", "孤立無援・理想家型", "外圧依存・消去法型", "安穏・思考停止型"]
            },
            "description_ja": { "type": ["string", "null"] }
          }
        },
        "contradictions": {
          "type": "array",
          "description": "矛盾検出結果（実装 v4.1.0+ の 6パターン）。変数間の不整合（例：S×LP乖離＝口先リーダーシップ）を検出。",
          "items": {
            "type": "object",
            "required": ["title_ja"],
            "additionalProperties": false,
            "properties": {
              "pattern_id": {
                "type": ["string", "null"],
                "description": "矛盾パターン識別子",
                "enum": [
                  "S_LP_divergence",
                  "C_LP_inverse",
                  "C_LP_external_dependency",
                  "S4_LP4_paper_plan",
                  "C2_C3_lip_service",
                  "L1_C3_stuck_despite_funds",
                  null
                ]
              },
              "title_ja": { "type": "string" },
              "description_ja": { "type": ["string", "null"] }
            }
          }
        },
        "damage_estimate_jpy": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Forg単体で算出する想定被害額（円）。計算式 daily × 14日 × 0.2 + 2（実装 v4.1.0）。Endeavor の damage_calculation より簡易版。"
        },
        "recommendations": {
          "type": "array",
          "description": "優先アクション提言（実装 v4.1.0+ の recs）。条件に応じて動的生成。priority 1/2/3 で重要度ソート済み。",
          "items": {
            "type": "object",
            "required": ["priority", "title_ja"],
            "additionalProperties": false,
            "properties": {
              "priority": { "type": "integer", "enum": [1, 2, 3], "description": "1=最優先, 2=推奨, 3=長期" },
              "title_ja": { "type": "string" },
              "description_ja": { "type": ["string", "null"] },
              "trigger_variable": {
                "type": ["string", "null"],
                "description": "このrecをトリガした変数/設問（例: S, L, sc.s4, budgetScore等）"
              }
            }
          }
        },
        "dominant_pattern": {
          "type": ["object", "null"],
          "description": "経営層向け4パターン診断（v4.3.0 新設）。最も悪い方向に逸脱した変数に基づき1つだけ選択。優先順位: LP > S > C > L。",
          "additionalProperties": false,
          "required": ["pattern_id"],
          "properties": {
            "pattern_id": {
              "type": "string",
              "description": "パターン識別子。S/L=高いほど悪い、C/LP=低いほど悪い。命名は「悪化状態を表す形容詞句」で統一。",
              "enum": [
                "leadership_weak",
                "silo_strong",
                "crisis_weak",
                "legacy_heavy"
              ]
            },
            "pattern_name_ja": {
              "type": "string",
              "description": "パターン名（日本語）。例: 縦割りが強い / 技術的負債が重い / 危機感が弱い / 変革意志が弱い",
              "examples": ["縦割りが強い", "技術的負債が重い", "危機感が弱い", "変革意志が弱い"]
            },
            "diagnosis_ja": {
              "type": "string",
              "description": "一言診断（日本語）"
            },
            "most_deviated_variable": {
              "type": "string",
              "description": "最も業界平均から悪化方向に逸脱した変数",
              "enum": ["S", "L", "C", "LP"]
            }
          }
        },
        "suggestion": {
          "type": ["object", "null"],
          "description": "経営層アクション提案（v4.3.0 新設）。ZT非依存文言。既存の recommendations とは別に、経営層向けの1行サマリとして表示。",
          "additionalProperties": false,
          "properties": {
            "action_ja": {
              "type": "string",
              "description": "経営層の次の一手（日本語）"
            },
            "reference_framework": {
              "type": ["string", "null"],
